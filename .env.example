# ─── Database (Neon Postgres recommended on Vercel) ───
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# ─── Better Auth ───────────────────────────────────────
# openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── BYOK encryption at rest (falls back to BETTER_AUTH_SECRET) ───
ENCRYPTION_KEY=""

# ─── Platform engine keys (used when a user has no BYOK key; each run costs 1 credit) ───
# Option A: one OpenRouter key covers every engine (web search via OpenRouter's
# :online plugin — Exa-based, no geo targeting, pricier per call).
# Option B: direct provider keys — cheaper, native web search, geo targeting.
# Direct keys take precedence per engine when both are set.
OPENROUTER_API_KEY=""

# OPENAI_API_KEY also powers Google AI Overview extraction (headless scrape + GPT).
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_GENERATIVE_AI_API_KEY=""
XAI_API_KEY=""
PERPLEXITY_API_KEY=""

# ─── Abuse guard: max credit-funded engine runs per day, platform-wide ───
# BYOK runs are never limited. Set 0 to disable. Default: 200.
DAILY_FREE_RUN_LIMIT="200"

# ─── Early-access seat cap: max total accounts. Existing users always
# sign in fine; only new account creation is blocked. 0 disables. ───
SIGNUP_CAP="30"

# ─── Optional: webhook fired when a user submits a credit request ───
# Receives the request + user profile as JSON (see src/lib/n8n.ts).
N8N_WEBHOOK_URL=""
N8N_WEBHOOK_USER=""
N8N_WEBHOOK_PASS=""

# Optional model overrides (direct mode)
# OPENAI_MODEL="gpt-5.1"
# ANTHROPIC_MODEL="claude-sonnet-4-5"
# GOOGLE_MODEL="gemini-2.5-flash"
# XAI_MODEL="grok-3-latest"
# PERPLEXITY_MODEL="sonar"
# AI_OVERVIEW_MODEL="gpt-5.1"

# Optional model overrides (OpenRouter mode)
# OPENROUTER_OPENAI_MODEL="openai/gpt-5.1"
# OPENROUTER_ANTHROPIC_MODEL="anthropic/claude-sonnet-4.5"
# OPENROUTER_GOOGLE_MODEL="google/gemini-2.5-flash"
# OPENROUTER_XAI_MODEL="x-ai/grok-3"
# OPENROUTER_PERPLEXITY_MODEL="perplexity/sonar"
# OPENROUTER_AI_OVERVIEW_MODEL="openai/gpt-5.1"
